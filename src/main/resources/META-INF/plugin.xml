<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.qmulda.dependencyanalyser</id>
    <name>DependencyAnalyser</name>
    <vendor>qmulda</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.idea.maven</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.qmulda.dependencyanalyser.toolWindow.MyToolWindowFactory"
                    id="DependencyAnalyser"
                    anchor="right"/>
        <applicationService serviceImplementation="com.github.qmulda.dependencyanalyser.services.EolIndexService"/>
    </extensions>
</idea-plugin>
